# Local secret/env overrides
.env
.env.*
!.env.example

# Claude Code per-project state
.claude/settings.local.json

# OpenClaw runtime state written inside the symlinked workspace
workspace/.openclaw/
workspace/memory/
workspace/.git/

# Node artifacts (for skills that pull dependencies)
node_modules/
**/node_modules/
package-lock.json
npm-debug.log*

# Chroma vector store — binary index files, grows continuously
data/

# Python virtualenv (managed by uv, repo-local)
.venv/
uv.lock
